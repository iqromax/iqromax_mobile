datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  customId  String   @unique // Like #0012
  role      String   @default("Student")
  name      String
  phone     String
  email     String   @unique
  password  String
  country   String?
  language  String?
  character String?
  status    String   @default("Faol")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
